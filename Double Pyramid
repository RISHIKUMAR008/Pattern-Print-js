let n = 5;

for (let i = 1; i <= n; i++) {
  let row = "";

  // left stars
  for (let j = 1; j <= i; j++) {
    row += "* ";
  }

  // gap
  row += "  ";

  // right stars
  for (let k = 1; k <= i; k++) {
    row += "* ";
  }

  console.log(row);
}
